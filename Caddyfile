{
    # FrankenPHP configuration
    frankenphp {
        num_threads 100
    }
}

:{$PORT:8080} {
    root * /app/public

    # Enable compression
    encode gzip zstd

    # Proxy WebSocket connections (Pusher protocol) to Reverb
    @reverb {
        path /app/*
    }
    reverse_proxy @reverb localhost:8081

    # Handle PHP files with FrankenPHP
    php_server

    # Try to serve static files, fallback to Laravel
    file_server
}
